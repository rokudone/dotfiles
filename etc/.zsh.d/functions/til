# XXX: hardcode
rootDir=${HOME}/til

if [ ! -d ${rootDir} ]; then
  echo "tilディレクトリが存在しません"
  return 1
fi

if [ $# = 0 ] ; then
  cd $rootDir
  return 0
fi


ext=$1
langDir=$rootDir/$ext
filename=$(date "+%Y-%m-%d")
file=$langDir/$filename.$ext

if [ ! -d ${langDir} ]; then
  mkdir $langDir
fi

if [ ! -f ${file} ]; then
  touch $file
fi

cd $langDir
ln -fs ./$filename.$ext sandbox.$ext
cd -

tm -c $langDir $ext
