[include]
  path = .gitconfig.local
[color]
  ui = false
  diff = true
  interactive = true
  status = true
  branch = true
[alias]
  st = status -sb
  cm = commit
  cma = commit -a
  br = branch
  co = checkout
  df = diff --color
  dfc = diff --cached
  dfh = diff HEAD
  pr = pull --rebase
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%ci) %C(bold blue)<%an>%Creset' --abbrev-commit
  lga = log --all --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=short
  lgg = log --stat --pretty=format:'%Cblue%h %Cgreen%ar %Cred%an %Creset%s %Cred%d'
  lgs = log --stat --abbrev-commit --date=relative
  fix = commit --amend -C HEAD
[gui]
  encoding = utf-8
[interactive]
  singlekey = true
  # diffFilter = nkf -w
  diffFilter = delta --color-only
[add.interactive]
  useBuiltin = false
[delta]
  side-by-side = true
  line-numbers = true
  navigate = true
  light = false
  syntax-theme = Monokai Extended Origin
  plus-style = "syntax #000000"
  minus-style = "syntax #000000"
[core]
  editor = nvim
  quotepath = false
  autocrlf = false
  safecrlf = false
  # pager = less=-R less
  # pager=LC_ALL=ja_JP.UTF-8 less -Sx4
  pager = delta
  excludesfile = ~/.gitignore_global
[pager]
  diff = delta
  show = delta
  log = delta
  reflog = delta
[i18n]
  commitencoding = UTF-8
[push]
  default = simple
[merge]
  tool = vimdiff
  conflictstyle = diff3
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true
[ghq]
  root = ~/projects
[diff]
  colorMoved = dimmed-zebra
  # 'blocks', 'zebra', 'dimmed-zebra', 'plain
[diff "cp932"]
  textconv=iconv -f cp932 -t utf-8
[diff "sjis"]
  textconv=iconv -f sjis -t utf-8
[init]
	templatedir = ~/.git_template
