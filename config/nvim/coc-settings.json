{
  "coc.preferences.formatOnSaveFiletypes": ["rust", "go", "typescript", "vue"],
  "diagnostic.messageTarget": "float",
  "diagnostic.checkCurrentLine": false,
  "diagnostic.virtualText": false,
  "diagnostic.virtualTextCurrentLineOnly": false,
  "signature.target": "float",
  "snippets.priority": 100,
  "snippets.snipmate.enable": false,
  "suggest.noselect":false,
  "suggest.minTriggerInputLength": 1,
  "suggest.preferCompleteThanJumpPlaceholder":true,
  "suggest.acceptSuggestionOnCommitCharacter": true,
  "suggest.snippetIndicator": "►",
  "suggest.maxCompleteItemCount": 20,
  "html.filetypes": [ "html" ],
  "css.lint.unknownAtRules": "ignore",
  "vetur.enable": false,
  "vetur.validation.template": true,
  "volar.takeOverMode.enabled": true,
  "volar.autoClosingTags": true,
  "volar-tools.enable": true,
  "tsserver.enable": false,
  "php-cs-fixer.enable": false,
  "psalm.enable": false,
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.headwind.runOnSave": false,
  "graphql.watcherPattern": "**/*.{graphql,gql,js,ts}",
  "graphql.filetypes": [
    "graphql",
    "javascript",
    "typescript"
  ],
  "list.insertMappings": {
    "<C-n>": "normal:j",
    "<C-p>": "normal:k",
    "<C-f>": "prompt:left",
    "<C-b>": "prompt:right"
  },
  "yaml.schemas": {
    "https://raw.githubusercontent.com/awslabs/goformation/master/schema/cloudformation.schema.json": "/cloudformation/*.yml"
  },
  "yaml.customTags": [
    "!Ref",
    "!Sub scalar",
    "!Sub sequence",
    "!Join sequence",
    "!FindInMap sequence",
    "!GetAtt scalar",
    "!GetAtt sequence",
    "!Base64 mapping",
    "!GetAZs",
    "!Select scalar",
    "!Select sequence",
    "!Split sequence",
    "!ImportValue",
    "!Condition",
    "!Equals sequence",
    "!And",
    "!If",
    "!Not",
    "!Or"
  ],
  "go.goplsoptions.experimentalWorkspaceModule": true,
  "diagnostic-languageserver.mergeConfig": true,
  "diagnostic-languageserver.filetypes": {
    "sh": "shellcheck",
    "bash": "shellcheck",
    "zsh": "shellcheck"
  },
  "diagnostic-languageserver.formatFiletypes": {
    "sh": "shfmt",
    "bash": "shfmt",
    "zsh": "shfmt"
  },
  "powershell.integratedConsole.showOnStartup": false,
  "explorer.width": 60,
  "explorer.root.strategies": [
    "sourceBuffer",
    "workspace",
    "cwd",
    "reveal"
  ],
  "explorer.keyMappings.global": {
    "i": false,
    "<c-o>": "noop",

    "*": "toggleSelection",
    "<tab>": "actionMenu",

    "gk": ["wait", "expandablePrev"],
    "gj": ["wait", "expandableNext"],
    "h": ["wait", "collapse"],
    "l": ["wait", "expandable?", "expand", "open"],
    "J": ["wait", "toggleSelection", "normal:j"],
    "K": ["wait", "toggleSelection", "normal:k"],
    "gl": ["wait", "expand:recursive"],
    "gh": ["wait", "collapse:recursive"],
    "<2-LeftMouse>": [
      "expandable?",
      ["expanded?", "collapse", "expand"],
      "open"
    ],
    "o": ["wait", "expanded?", "collapse", "expand"],
    "<cr>": ["wait", "expandable?", "cd", ["open", "quit"]],
    "e": ["open", "quit"],
    "s": ["open:split", "quit"],
    "v": ["open:vsplit", "quit"],
    "t": ["open:tab", "quit"],
    "<bs>": ["wait", "gotoParent"],
    "gs": ["wait", "reveal:select"],
    "il": "preview:labeling",
    "ic": "preview:content",
    "Il": "previewOnHover:toggle:labeling",
    "Ic": "previewOnHover:toggle:content",
    "II": "previewOnHover:disable",

    "yp": "copyFilepath",
    "yn": "copyFilename",
    "yy": "copyFile",
    "mm": "cutFile",
    "p": "pasteFile",
    "dd": "delete",
    "dF": "deleteForever",

    "a": "addFile",
    "A": "addDirectory",
    "r": "rename",

    "zh": "toggleHidden",
    "g<dot>": "toggleHidden",
    "R": "refresh",

    "?": "help",
    "q": "quit",
    "<esc>": "esc",
    "X": "systemExecute",
    "gd": "listDrive",

    "f": "search",
    "F": "searchRecursive",

    "gf": "gotoSource:file",
    "gb": "gotoSource:buffer",

    "[[": ["wait", "sourcePrev"],
    "]]": ["wait", "sourceNext"],

    "[i": ["wait", "indentPrev"],
    "]i": ["wait", "indentNext"],

    "[m": ["wait", "markPrev:modified"],
    "]m": ["wait", "markNext:modified"],

    "[d": ["wait", "markPrev:diagnosticError:diagnosticWarning"],
    "]d": ["wait", "markNext:diagnosticError:diagnosticWarning"],
    "[D": ["wait", "markPrev:diagnosticError"],
    "]D": ["wait", "markNext:diagnosticError"],

    "[c": ["wait", "markPrev:git"],
    "]c": ["wait", "markNext:git"],
    "<<": "gitStage",
    ">>": "gitUnstage"
  },

  "languageserver": {
    "intelephense": {
      "command": "intelephense",
      "args": ["--stdio"],
      "filetypes": ["php"],
      "initializationOptions": {
        "storagePath": "/tmp/intelephense"
      }
    },
    "yaml": {
      "command": "yaml-language-server",
      "args": ["--stdio"],
      "filetypes": ["yaml"]
    },
    "haskell": {
      "command": "haskell-language-server-wrapper",
      "args": ["--lsp"],
      "rootPatterns": ["*.cabal", "stack.yaml", "cabal.project", "package.yaml", "hie.yaml"],
      "filetypes": ["haskell", "lhaskell"]
    }
  }
}
